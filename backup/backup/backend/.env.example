# Copy to .env and fill in real values. Do NOT commit the real .env.

# ── Database ────────────────────────────────────────────────
DB_USER=hansa_user
DB_HOST=192.168.5.39
DB_NAME=Ticketing_Tool_Hansa
DB_PASSWORD=__set_me__
DB_PORT=5432
PORT=3008

# Base URL used to build approval email links — must point at this backend's host:port.
APP_BASE_URL=http://192.168.5.39:3008

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=__set_a_long_random_secret__

# ── SMTP shared settings ────────────────────────────────────
SMTP_PORT=587
SMTP_HOST=smtp.office365.com

# ── SMTP Account 1: Hansa Cequity ───────────────────────────
SMTP_USER_HC=no-reply@hansacequity.com
SMTP_PASS_HC=__set_me__

# ── SMTP Account 2: Hansa Direct / Autosense ────────────────
SMTP_USER_HD=ticketing.portal@hansadirect.com
SMTP_PASS_HD=__set_me__

# ── Optional ────────────────────────────────────────────────
